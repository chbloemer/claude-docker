# Optional: workspace path (set automatically by claude-docker.sh wrapper)
# Only needed when using docker compose directly.
# WORKSPACE_PATH=/path/to/your/project

# Optional: set this to use an API key instead of OAuth login
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Optional: UID of your host user (run "id -u" to find out).
# Ensures mounted files are read/writable without permission issues.
# Default: 501 (macOS default)
# HOST_UID=501
